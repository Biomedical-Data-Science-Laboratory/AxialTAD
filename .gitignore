# ============================================================================
# AxialTAD — .gitignore
# Excludes large data + trained models + caches; keeps code, docs, figures.
# ============================================================================

# ----------------------------------------------------------------------------
# Trained models (large, regenerable via scripts/train.py)
# ----------------------------------------------------------------------------
trained_models/

# ----------------------------------------------------------------------------
# Hi-C raw data + KR-balanced matrices + intermediate H5
# ----------------------------------------------------------------------------
data_4dn/
matrix_kr_25kb/
matrix_raw_25kb/
h5_input_v2/
h5_input_raw/

# ----------------------------------------------------------------------------
# Reference outputs (OnTAD + HiCExplorer raw outputs are large + regenerable)
# ----------------------------------------------------------------------------
ontad_output/
ontad_output_raw/
hicexplorer_output_v2/
hicexplorer_output_raw/

# ----------------------------------------------------------------------------
# Sample patches (regenerable via scripts/generate_samples.py)
# ----------------------------------------------------------------------------
samples/
samples_raw/

# ----------------------------------------------------------------------------
# Checkpoints: ignore locally-trained model files but keep the bundled
# release checkpoint in the repo.
# ----------------------------------------------------------------------------
checkpoints/*.pt
checkpoints/*.h5
checkpoints/*.weights.h5
!checkpoints/axialtad_main.weights.h5

# ----------------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------------
logs/
*.log

# ----------------------------------------------------------------------------
# OnTAD compiled binary + source (regenerable from upstream)
# ----------------------------------------------------------------------------
ontad/

# ----------------------------------------------------------------------------
# Python caches
# ----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
.pytest_cache/

# ----------------------------------------------------------------------------
# OS / editor noise
# ----------------------------------------------------------------------------
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# ----------------------------------------------------------------------------
# Temporary working files
# ----------------------------------------------------------------------------
/tmp/
*.tmp
